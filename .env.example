# ============================================================
# teech-platform — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to version control.
# All variables marked REQUIRED must be set before npm run dev.
# ============================================================

# ── SUPABASE (REQUIRED) ──────────────────────────────────────
# Project: Sydney region (ap-southeast-2) — student data stays in Australia
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── ANTHROPIC (REQUIRED) ─────────────────────────────────────
# Used for: question generation, session briefs, learning identity paragraphs
# Note: API calls use minimum-necessary data. Student PII is never sent to Claude.
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── STRIPE (REQUIRED for marketplace) ────────────────────────
# Public key: used client-side for payment elements
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
# Secret key: server-side only — never expose to client
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
# Webhook secret: for validating Stripe webhook events
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ── PLATFORM CONFIG (REQUIRED) ───────────────────────────────
# Base URL for the platform (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Platform environment
NODE_ENV=development
# Platform version (used in audit logs)
NEXT_PUBLIC_PLATFORM_VERSION=0.1.0

# ── SECURITY (REQUIRED) ──────────────────────────────────────
# Secret for signing badge credentials (min 64 chars, random)
BADGE_SIGNING_SECRET=your-random-64-char-secret-for-badge-signing
# Secret for session tokens (min 64 chars, random)
SESSION_TOKEN_SECRET=your-random-64-char-secret-for-session-tokens

# ── EMAIL (REQUIRED for notifications) ───────────────────────
# Resend (recommended) or other transactional email provider
RESEND_API_KEY=re_your-resend-api-key
SYSTEM_EMAIL_FROM=noreply@teech.au
SUPPORT_EMAIL=support@teech.au

# ── IDENTITY VERIFICATION (REQUIRED for tutor onboarding) ────
# Stripe Identity — for tutor KYC
# Uses same Stripe keys above — no separate key needed

# ── OPTIONAL: MONITORING ─────────────────────────────────────
# Sentry for error tracking (add in Phase 2)
# SENTRY_DSN=https://your-sentry-dsn
# NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn
